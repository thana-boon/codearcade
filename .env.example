# ตั้งค่า PostgreSQL (ใช้โดย docker-compose)
POSTGRES_USER=arcade
POSTGRES_PASSWORD=arcade_password
POSTGRES_DB=code_arcade

# connection string สำหรับแอป
# - ตอนรันด้วย docker compose ใช้ host เป็นชื่อ service "db"
# - ตอนรัน local dev (postgres บนเครื่อง) เปลี่ยนเป็น localhost
DATABASE_URL=postgres://arcade:arcade_password@db:5432/code_arcade
